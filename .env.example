# Environment variables for Book Lamp

# Google Sheets Configuration
# The app will automatically create/use "BookLampData" in production
# and "DevBookLampData" in development.
FLASK_ENV=development
GOOGLE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=False

# AI Recommendations
# The app uses the OpenAI SDK, which is compatible with many providers.
# Example below uses Google Gemini (free tier available, no CC required)
LLM_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
