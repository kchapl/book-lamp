# Environment variables for Book Lamp

# Database Configuration
DATABASE_URL=postgresql://book_lamp:book_lamp@localhost:5432/book_lamp_dev

# Google One Tap Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here

# Service Account Key (for migration script only)
# Set GOOGLE_SERVICE_ACCOUNT_KEY with contents of service account JSON file
# export GOOGLE_SERVICE_ACCOUNT_KEY=$(cat path/to/service-account.json)

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=False  # Set to True for development debugging (doesn't affect authentication)

# AI Recommendations
# The app uses the OpenAI SDK, which is compatible with many providers.
# Example below uses Google Gemini (free tier available, no CC required)
LLM_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
